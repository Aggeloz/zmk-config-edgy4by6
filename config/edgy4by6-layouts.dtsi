// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Column stagger: outer pinky cols +50, ring +25, middle/index 0
        // Left cols 0-5 at x=0..500, right cols 6-11 at x=650..1150
        keys  //                     w   h    x    y     rot    rx    ry
            // Row 0
            = <&key_physical_attrs 100 100    0   50       0     0     0>  // 0  ESC
            , <&key_physical_attrs 100 100  100   50       0     0     0>  // 1  1
            , <&key_physical_attrs 100 100  200   25       0     0     0>  // 2  2
            , <&key_physical_attrs 100 100  300    0       0     0     0>  // 3  3
            , <&key_physical_attrs 100 100  400    0       0     0     0>  // 4  4
            , <&key_physical_attrs 100 100  500   25       0     0     0>  // 5  5
            , <&key_physical_attrs 100 100  650   25       0     0     0>  // 6  6
            , <&key_physical_attrs 100 100  750    0       0     0     0>  // 7  7
            , <&key_physical_attrs 100 100  850    0       0     0     0>  // 8  8
            , <&key_physical_attrs 100 100  950   25       0     0     0>  // 9  9
            , <&key_physical_attrs 100 100 1050   50       0     0     0>  // 10 0
            , <&key_physical_attrs 100 100 1150   50       0     0     0>  // 11 DEL
            // Row 1
            , <&key_physical_attrs 100 100    0  150       0     0     0>  // 12 TAB
            , <&key_physical_attrs 100 100  100  150       0     0     0>  // 13 Q
            , <&key_physical_attrs 100 100  200  125       0     0     0>  // 14 W
            , <&key_physical_attrs 100 100  300  100       0     0     0>  // 15 E
            , <&key_physical_attrs 100 100  400  100       0     0     0>  // 16 R
            , <&key_physical_attrs 100 100  500  125       0     0     0>  // 17 T
            , <&key_physical_attrs 100 100  650  125       0     0     0>  // 18 Y
            , <&key_physical_attrs 100 100  750  100       0     0     0>  // 19 U
            , <&key_physical_attrs 100 100  850  100       0     0     0>  // 20 I
            , <&key_physical_attrs 100 100  950  125       0     0     0>  // 21 O
            , <&key_physical_attrs 100 100 1050  150       0     0     0>  // 22 P
            , <&key_physical_attrs 100 100 1150  150       0     0     0>  // 23 BSPC
            // Row 2
            , <&key_physical_attrs 100 100    0  250       0     0     0>  // 24 LSHFT
            , <&key_physical_attrs 100 100  100  250       0     0     0>  // 25 A
            , <&key_physical_attrs 100 100  200  225       0     0     0>  // 26 S
            , <&key_physical_attrs 100 100  300  200       0     0     0>  // 27 D
            , <&key_physical_attrs 100 100  400  200       0     0     0>  // 28 F
            , <&key_physical_attrs 100 100  500  225       0     0     0>  // 29 G
            , <&key_physical_attrs 100 100  650  225       0     0     0>  // 30 H
            , <&key_physical_attrs 100 100  750  200       0     0     0>  // 31 J
            , <&key_physical_attrs 100 100  850  200       0     0     0>  // 32 K
            , <&key_physical_attrs 100 100  950  225       0     0     0>  // 33 L
            , <&key_physical_attrs 100 100 1050  250       0     0     0>  // 34 ;
            , <&key_physical_attrs 100 100 1150  250       0     0     0>  // 35 '
            // Row 3
            , <&key_physical_attrs 100 100    0  350       0     0     0>  // 36 LCTRL
            , <&key_physical_attrs 100 100  100  350       0     0     0>  // 37 Z
            , <&key_physical_attrs 100 100  200  325       0     0     0>  // 38 X
            , <&key_physical_attrs 100 100  300  300       0     0     0>  // 39 C
            , <&key_physical_attrs 100 100  400  300       0     0     0>  // 40 V
            , <&key_physical_attrs 100 100  500  325       0     0     0>  // 41 B
            , <&key_physical_attrs 100 100  650  325       0     0     0>  // 42 N
            , <&key_physical_attrs 100 100  750  300       0     0     0>  // 43 M
            , <&key_physical_attrs 100 100  850  300       0     0     0>  // 44 ,
            , <&key_physical_attrs 100 100  950  325       0     0     0>  // 45 .
            , <&key_physical_attrs 100 100 1050  350       0     0     0>  // 46 /
            , <&key_physical_attrs 100 100 1150  350       0     0     0>  // 47 RCTRL
            // Thumb cluster (4 left: RC(4,2-5), 4 right: RC(4,6-9))
            , <&key_physical_attrs 100 100  200  450       0     0     0>  // 48 LWIN
            , <&key_physical_attrs 100 100  300  475       0     0     0>  // 49 LALT
            , <&key_physical_attrs 100 100  400  475       0     0     0>  // 50 SPC
            , <&key_physical_attrs 100 100  500  450       0     0     0>  // 51 lt1/A
            , <&key_physical_attrs 100 100  650  450       0     0     0>  // 52 (none)
            , <&key_physical_attrs 100 100  750  475       0     0     0>  // 53 RET
            , <&key_physical_attrs 100 100  850  475       0     0     0>  // 54 [
            , <&key_physical_attrs 100 100  950  450       0     0     0>  // 55 ]
            ;
    };
};
